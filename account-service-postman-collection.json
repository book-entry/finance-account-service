{
  "info": {
    "name": "finance-account-service",
    "description": "Account Service (port 8081) - spec §3.1. Scenario names mirror the unit test method names in AccountControllerTest / AccountServiceImplTest for cross-reference.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8081", "type": "string" },
    { "key": "userId",    "value": "user-123",              "type": "string" },
    { "key": "accountId", "value": "00000000-0000-0000-0000-000000000000", "type": "string" },
    { "key": "otherAccountId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" }
  ],
  "item": [
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Account - Happy Path (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-User-Id",    "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Main Checking\",\n  \"bankName\": \"DBS Bank\",\n  \"bankCode\": \"DBSSSGSG\",\n  \"accountCode\": \"1234-5678-9012\",\n  \"accountType\": \"ASSET\",\n  \"currency\": \"USD\",\n  \"openingBalance\": 1000.00,\n  \"description\": \"Primary household account\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "pm.expect(body.success).to.eql(true);",
                  "pm.expect(body.data.accountId).to.be.a('string');",
                  "pm.expect(body.data.status).to.eql('ACTIVE');",
                  "pm.collectionVariables.set('accountId', body.data.accountId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Account - Missing bankName (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-User-Id",    "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Missing Bank\",\n  \"accountType\": \"ASSET\",\n  \"currency\": \"USD\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });",
                  "var body = pm.response.json();",
                  "pm.expect(body.success).to.eql(false);",
                  "pm.expect(body.error.code).to.eql('VAL_001');"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Account - Missing X-User-Id (400)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"No Header\",\n  \"bankName\": \"DBS Bank\",\n  \"accountType\": \"ASSET\",\n  \"currency\": \"USD\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });",
                  "pm.expect(pm.response.json().error.code).to.eql('VAL_001');"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Account - Invalid Currency (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-User-Id",    "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Bad CCY\",\n  \"bankName\": \"DBS Bank\",\n  \"accountType\": \"ASSET\",\n  \"currency\": \"ZZZ\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });",
                  "pm.expect(pm.response.json().error.code).to.eql('INVALID_CURRENCY');"
                ]
              }
            }
          ]
        },
        {
          "name": "List Accounts - Happy Path (200)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.expect(body.success).to.eql(true);",
                  "pm.expect(body.data).to.be.an('array');"
                ]
              }
            }
          ]
        },
        {
          "name": "List Accounts - Status & Type Filter (200)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts?status=ACTIVE&type=ASSET",
              "host": ["{{baseUrl}}"], "path": ["v1", "accounts"],
              "query": [
                { "key": "status", "value": "ACTIVE" },
                { "key": "type",   "value": "ASSET" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.expect(pm.response.json().data).to.be.an('array');"
                ]
              }
            }
          ]
        },
        {
          "name": "List Accounts - Missing X-User-Id (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/v1/accounts", "host": ["{{baseUrl}}"], "path": ["v1", "accounts"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });",
                  "pm.expect(pm.response.json().error.code).to.eql('VAL_001');"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Account - Happy Path (200)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": { "raw": "{{baseUrl}}/v1/accounts/{{accountId}}", "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "{{accountId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.expect(body.success).to.eql(true);",
                  "pm.expect(body.data.accountId).to.be.a('string');"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Account - Non-Existent (404)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/00000000-0000-0000-0000-deadbeef0000",
              "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "00000000-0000-0000-0000-deadbeef0000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });",
                  "pm.expect(pm.response.json().error.code).to.eql('ACCOUNT_NOT_FOUND');"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Account - Happy Path (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "X-User-Id",    "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/v1/accounts/{{accountId}}", "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "{{accountId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"Main Checking (Renamed)\",\n  \"description\": \"Renamed via Postman\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.expect(pm.response.json().data.accountName).to.include('Renamed');"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Account - Non-Existent (404)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "X-User-Id",    "value": "{{userId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/00000000-0000-0000-0000-deadbeef0000",
              "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "00000000-0000-0000-0000-deadbeef0000"]
            },
            "body": { "mode": "raw", "raw": "{ \"accountName\": \"Ghost\" }" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });",
                  "pm.expect(pm.response.json().error.code).to.eql('ACCOUNT_NOT_FOUND');"
                ]
              }
            }
          ]
        },
        {
          "name": "Close Account - Happy Path (204)",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": { "raw": "{{baseUrl}}/v1/accounts/{{accountId}}", "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "{{accountId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 204', function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Close Account - Non-Existent (404)",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/00000000-0000-0000-0000-deadbeef0000",
              "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "00000000-0000-0000-0000-deadbeef0000"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });",
                  "pm.expect(pm.response.json().error.code).to.eql('ACCOUNT_NOT_FOUND');"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate Accounts - Mixed IDs (200)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": {
              "raw": "{{baseUrl}}/v1/accounts/validate?ids={{accountId}},{{otherAccountId}}",
              "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "validate"],
              "query": [ { "key": "ids", "value": "{{accountId}},{{otherAccountId}}" } ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.expect(body.data.valid).to.be.an('array');",
                  "pm.expect(body.data.invalid).to.be.an('array');"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate Accounts - Missing ids param (400)",
          "request": {
            "method": "GET",
            "header": [ { "key": "X-User-Id", "value": "{{userId}}" } ],
            "url": { "raw": "{{baseUrl}}/v1/accounts/validate", "host": ["{{baseUrl}}"], "path": ["v1", "accounts", "validate"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });",
                  "pm.expect(pm.response.json().error.code).to.eql('VAL_001');"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
